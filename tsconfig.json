{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@lib/*": ["./src/lib/*"],
      "@config/*": ["./src/config/*"],
      "@types/*": ["./src/types/*"],
      "@components/*": ["./src/components/*"],
      "@catalogs/*": ["./src/modules/catalogs/*"],
      "@clauses/*": ["./src/modules/clauses/*"],
      "@contracts/*": ["./src/modules/contracts/*"],
      "@locations/*": ["./src/modules/locations/*"],
      "@payments/*": ["./src/modules/payments/*"],
      "@properties/*": ["./src/modules/properties/*"],
      "@services/*": ["./src/modules/services/*"],
      "@uploads/*": ["./src/modules/uploads/*"],
      "@users/*": ["./src/modules/users/*"],
      "@visits/*": ["./src/modules/visits/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
